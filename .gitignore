# Build artifacts
/dist/
/bin/

# Model artifacts — large, downloaded per-machine, never committed.
# Tests skip cleanly when these aren't present. Populate via symlink
# into ~/.cache/huggingface/... or `ken download-model --to ...`.
testdata/model
testdata/encoder-model
testdata/gemma-3-270m
*.safetensors

# Go
*.test
*.out
/vendor/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Python tooling (pin_inference.py + pin_encoder.py regenerate the
# golden fixtures; their venvs are reproducible and not committed)
.venv/
__pycache__/
*.pyc

# Generated fixture at root — the canonical copies live under testdata/
/ken_golden.json
/aikit_golden.json

# 100k-input tokenizer parity dump (regenerated via scripts/parity_dump.py).
# Tens of MB; never committed.
testdata/parity.jsonl

# M3 forward full-logit dump — ~2.6 MB, per-machine, regenerated by
# scripts/pin_gemma_forward.py. The compact gemma_forward_golden.json IS committed.
testdata/gemma_forward_full.json

# M5 sliding-window full-logit dump — per-machine, regenerated by
# scripts/pin_gemma_window.py. The compact gemma_window_golden.json IS committed.
testdata/gemma_window_full.json

# G1 sharded-checkpoint fixture — per-machine, regenerated by
# scripts/shard_checkpoint.py from testdata/gemma-3-270m. ~512 MB, never committed.
testdata/gemma-3-270m-sharded

# Qwen3 parity model — per-machine, downloaded via huggingface_hub; never committed.
testdata/qwen3-1.7b

# Qwen2.5-0.5B GGUF (qwen2 GGUF-architecture parity) — per-machine, downloaded via
# huggingface_hub (Qwen/Qwen2.5-0.5B-Instruct-GGUF, Q8_0, ~0.6 GB). Validated by
# TestGGUF_qwen2_parity against the committed qwen2 f32 oracle; never committed.
testdata/qwen2-gguf

# Qwen3-1.7B GGUF (qwen3 GGUF-architecture parity) — per-machine, downloaded via
# huggingface_hub (Qwen/Qwen3-1.7B-GGUF, Q8_0, ~1.8 GB). Validated by
# TestGGUF_qwen3_parity against the committed qwen3 f32 oracle; never committed.
testdata/qwen3-gguf

# Qwen3 forward full-logit dump — per-machine, regenerated by scripts/pin_qwen3_forward.py.
testdata/qwen3_forward_full.json

# Llama-3 tokenizer (G3 byte-level parity) — per-machine, downloaded via
# huggingface_hub (e.g. NousResearch/Meta-Llama-3-8B, a non-gated mirror of the
# meta-llama tokenizer). Only the small golden is committed; never the 9 MB json.
testdata/llama3-tokenizer

# Mellum2 tokenizer (byte-level digit-isolation parity) — per-machine, downloaded
# via huggingface_hub (JetBrains/Mellum2-12B-A2.5B-Instruct, tokenizer.json +
# tokenizer_config.json only). Only the small golden is committed; never the 7 MB
# tokenizer.json. Regenerate: scripts/pin_mellum2_tokenizer.py
testdata/mellum2-tokenizer

# Llama-adapter forward-parity model — per-machine, downloaded via
# huggingface_hub (TinyLlama/TinyLlama-1.1B-Chat-v1.0, Llama-2 arch, ungated).
# Only the small golden is committed; never the weights or the full-logit dump.
testdata/tinyllama-1.1b
testdata/llama_forward_full.json

# Llama-3.2-1B (G4 llama3 rope-scaling parity) — per-machine, downloaded via
# huggingface_hub (unsloth/Llama-3.2-1B-Instruct, ungated). Only the small
# golden is committed; never the weights or the full-logit dump.
testdata/llama3.2-1b
testdata/llama32_forward_full.json

# Qwen2.5-0.5B (qwen2 family / QKV-bias parity) — per-machine, downloaded via
# huggingface_hub (Qwen/Qwen2.5-0.5B-Instruct, ungated). Only the small golden
# is committed; never the weights or the full-logit dump.
testdata/qwen2.5-0.5b
testdata/qwen2_forward_full.json

# TinyMistral-248M (mistral family / sliding-window parity) — per-machine,
# downloaded via huggingface_hub (Locutusque/TinyMistral-248M, ungated). Only
# the small golden is committed; never the weights or the full-logit dump.
testdata/tinymistral-248m
testdata/mistral_forward_full.json

# GPT-2 small (G5 LayerNorm/learned-pos/non-gated-MLP parity) — per-machine,
# downloaded via huggingface_hub (openai-community/gpt2, ungated). Only the
# small golden is committed; never the weights or the full-logit dump.
testdata/gpt2
testdata/gpt2_forward_full.json

# Mixtral-tiny (G6 MoE parity) — per-machine, downloaded via huggingface_hub
# (dacorvo/Mixtral-tiny, ungated). Only the small golden is committed; never
# the weights or the full-logit dump.
testdata/mixtral-tiny
testdata/mixtral_forward_full.json

# Quantized GGUF checkpoints (G7) — per-machine, downloaded via huggingface_hub
# (TheBloke/TinyLlama-1.1B-Chat-v1.0-GGUF, ungated). Validated against the
# committed f32 llama golden; the .gguf files themselves are never committed.
testdata/tinyllama-gguf

# Byte-level GGUF tokenizer fixture (unsloth/Llama-3.2-1B-Instruct-GGUF,
# Q4_K_M) — per-machine. TestLoadGGUF_byteLevelMatchesJSON cross-checks it
# against the committed testdata/llama3.2-1b/tokenizer.json; never committed.
testdata/llama32-gguf

# Mellum2 GGUF (CodeFault/Mellum2-12B-A2.5B-Instruct-GGUF, Q4_K_M, ~8 GB) —
# per-machine. The mellum GGUF smoke test loads it when present; never committed.
testdata/mellum-gguf

# GPTQ / AWQ checkpoints (TheBloke/TinyLlama-1.1B-Chat-v1.0-{GPTQ,AWQ}, 4-bit,
# ~0.8 GB each) — per-machine. TestGPTQ_parity / TestAWQ_parity validate them
# against the committed f32 llama golden (same model); the weights aren't committed.
testdata/tinyllama-gptq
testdata/tinyllama-awq

# Local HF token notes — per-machine secret, never commit (rotate + delete).
docs/keepers.txt
